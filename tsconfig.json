{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "extensions",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "bun"]
  },
  "include": ["extensions/**/*"]
}
